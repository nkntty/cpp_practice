#include <iostream>
#include <fstream>
#include <unordered_map>
#include <string>
using namespace std;

int main() {
    string filename;
    ifstream file;

    do {
        cout << "Enter filename: ";
        cin >> filename;
        file.open(filename);
    } while (!file);

    unordered_map<string, int> wordCount;
    string word;

    while (file >> word) {
        wordCount[word]++;
    }

    for (const auto& pair : wordCount) {
        cout << pair.first << " " << pair.second << endl;   //.first .second can be used with ITERATOR
    }

    return 0;
}
